# This file is a reference. Copy env vars to the appropriate app-level .env:
#   apps/server/.env      — server config
#   apps/dashboard/.env   — dashboard config

# ─── apps/server/.env ─────────────────────────────────────────────

# Server
PORT=3001
MONGODB_URI=mongodb://localhost:27017/ludus
NODE_ENV=development

# Authentication & repo
CLAUDE_CODE_OAUTH_TOKEN=
GH_TOKEN=
GITHUB_REPO_URL=
BASE_BRANCH=main

# Agent defaults
DEFAULT_MODEL=claude-sonnet-4-6
CODER_TIMEOUT_MS=1800000
ORCHESTRATOR_TIMEOUT_MS=1200000
REVIEWER_TIMEOUT_MS=900000
DEFAULT_BUDGET_USD=5

# Job queue
CONCURRENT_AGENT_SLOTS=3
CONCURRENT_INFRA_SLOTS=8
JOB_POLL_INTERVAL_MS=5000

# SSE
SSE_HEARTBEAT_INTERVAL_MS=30000

# Retention
AGENT_EVENT_TTL_DAYS=30
JOB_RETENTION_DAYS=30

# Notifications
DISCORD_WEBHOOK_URL=

# Project repo — the target project the harness drives. Points to a local
# checkout that contains .harness/project.yaml. When unset, the harness
# boots in "no project loaded" mode (dashboard shows empty state, cycle
# creation is blocked). See basic-doc/plan-harness-decoupling.md.
# GAME_REPO_LOCAL_PATH is accepted as a deprecated alias for one release.
PROJECT_REPO_LOCAL_PATH=

# ─── apps/dashboard/.env ──────────────────────────────────────────

NEXT_PUBLIC_API_URL=http://localhost:3001/api
